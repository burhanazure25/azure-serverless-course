{
    "version": "2.0",
    "telemetryMode": "OpenTelemetry",
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            },
            "enableLiveMetrics": true
        }
    },
    "extensions": {
        "serviceBus": {
            "messageHandlerOptions": {
                "autoComplete": true,
                "maxConcurrentCalls": 1,
                "maxAutoRenewDuration": "00:05:00"
            }
        }
    }
}
